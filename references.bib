% Academic Bibliography — single source of truth
% Sync this file into LaTeX projects and point Obsidian Citations plugin here.

% ── Article ────────────────────────────────────────────────────────────────────
% @article{key,
%   author  = {Last, First and Last2, First2},
%   title   = {Title of the Article},
%   journal = {Journal Name},
%   year    = {2024},
%   volume  = {1},
%   number  = {1},
%   pages   = {1--10},
%   doi     = {10.xxxx/xxxxx},
% }

% ── Book ───────────────────────────────────────────────────────────────────────
% @book{key,
%   author    = {Last, First},
%   title     = {Title of the Book},
%   publisher = {Publisher Name},
%   year      = {2024},
%   address   = {City},
%   isbn      = {978-x-xxx-xxxxx-x},
% }

% ── InCollection (book chapter) ────────────────────────────────────────────────
% @incollection{key,
%   author    = {Last, First},
%   title     = {Chapter Title},
%   booktitle = {Book Title},
%   editor    = {Editor Last, Editor First},
%   publisher = {Publisher Name},
%   year      = {2024},
%   pages     = {1--20},
% }

% ── Conference paper ───────────────────────────────────────────────────────────
% @inproceedings{key,
%   author    = {Last, First},
%   title     = {Paper Title},
%   booktitle = {Proceedings of the Conference},
%   year      = {2024},
%   pages     = {1--8},
%   doi       = {10.xxxx/xxxxx},
% }

% ── Misc / online resource ─────────────────────────────────────────────────────
% @misc{key,
%   author       = {Last, First},
