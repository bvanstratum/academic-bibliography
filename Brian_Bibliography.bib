@Article{	  yim2019review,
  author	= "Seo, Jungwon and Paik, Jamie and Yim, Mark",
  title		= "Modular Reconfigurable Robotics",
  journal	= "Annual Review of Control, Robotics, and Autonomous
		  Systems",
  year		= "2019",
  volume	= "2",
  number	= "Volume 2, 2019",
  pages		= "63-88",
  doi		= "https://doi.org/10.1146/annurev-control-053018-023834",
  url		= "https://www.annualreviews.org/content/journals/10.1146/annurev-control-053018-023834",
  publisher	= "Annual Reviews",
  issn		= "2573-5144",
  type		= "Journal Article",
  keywords	= "distributed robot systems",
  abstract	= "This article reviews the current state of the art in the
		  development of modular reconfigurable robot (MRR) systems
		  and suggests promising future research directions. A wide
		  variety of MRR systems have been presented to date, and
		  these robots promise to be versatile, robust, and low cost
		  compared with other conventional robot systems. MRR systems
		  thus have the potential to outperform traditional systems
		  with a fixed morphology when carrying out tasks that
		  require a high level of flexibility. We begin by
		  introducing the taxonomy of MRRs based on their hardware
		  architecture. We then examine recent progress in the
		  hardware and the software technologies for MRRs, along with
		  remaining technical issues. We conclude with a discussion
		  of open challenges and future research directions."
}

