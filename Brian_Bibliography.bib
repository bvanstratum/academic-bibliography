@Article{	  christianson_2020,
  doi		= {10.1088/1748-3190/abbc72},
  url		= {https://dx.doi.org/10.1088/1748-3190/abbc72},
  year		= {2020},
  month		= {dec},
  publisher	= {IOP Publishing},
  volume	= {16},
  number	= {1},
  pages		= {016014},
  author	= {Christianson, Caleb and Cui, Yi and Ishida, Michael and
		  Bi, Xiaobo and Zhu, Qiang and Pawlak, Geno and Tolley,
		  Michael T},
  title		= {Cephalopod-inspired robot capable of cyclic jet propulsion
		  through shape change},
  journal	= {Bioinspiration \& Biomimetics},
  abstract	= {The compliance and conformability of soft robots provide
		  inherent advantages when working around delicate objects or
		  in unstructured environments. However, rapid locomotion in
		  soft robotics is challenging due to the slow propagation of
		  motion in compliant structures, particularly underwater.
		  Cephalopods overcome this challenge using jet propulsion
		  and the added mass effect to achieve rapid, efficient
		  propulsion underwater without a skeleton. Taking
		  inspiration from cephalopods, here we present an underwater
		  robot with a compliant body that can achieve repeatable jet
		  propulsion by changing its internal volume and
		  cross-sectional area to take advantage of jet propulsion as
		  well as the added mass effect. The robot achieves a maximum
		  average thrust of 0.19 N and maximum average and peak
		  swimming speeds of 18.4 cm s−1 (0.54 body lengths/s) and
		  32.1 cm s−1 (0.94 BL/s), respectively. We also
		  demonstrate the use of an onboard camera as a sensor for
		  ocean discovery and environmental monitoring
		  applications.}
}

